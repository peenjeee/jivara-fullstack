# Server Configuration
PORT=3001
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=development

# API Configuration
API_URL=http://localhost:3001

# Food AI
FOOD_AI_INFERENCE_URL=https://food-detection.jivara.web.id
FOOD_AI_TIMEOUT_MS=25000
FOOD_AI_IMAGE_MAX_SIZE=1280
FOOD_AI_IMAGE_QUALITY=75
FOOD_AI_ALLOW_LOCAL_FALLBACK=false
FOOD_REASONING_API_URL=http://ai.jivara.web.id
FOOD_REASONING_TIMEOUT_MS=10000

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
# Optional Supabase Session Pooler URL for IPv4-only production hosts
SUPABASE_POOLER_URL=
DATABASE_MAX_CONNECTIONS=10
DATABASE_IDLE_TIMEOUT_SECONDS=20
DATABASE_MAX_LIFETIME_SECONDS=1800
DATABASE_CONNECT_TIMEOUT_SECONDS=10
FRONTEND_URL=http://localhost:3000
API_RATE_LIMIT_MAX=600
API_RATE_LIMIT_WINDOW_MS=900000

# Web Push Configuration (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@jivara.app

# Medication Reminder Scheduler
ENABLE_REMINDER_SCHEDULER=true
# Set false in production web dynos and run npm run start:reminder-worker separately.
REMINDER_SCHEDULER_RUN_IN_WEB=true
REMINDER_SCHEDULER_INTERVAL_MS=60000
REMINDER_LOOKBACK_MINUTES=2

# Short-lived caches reduce repeated Supabase roundtrips across parallel dashboard requests.
AUTH_USER_CACHE_TTL_MS=5000
ACCESS_SCOPE_CACHE_TTL_MS=5000
ADHERENCE_CACHE_TTL_MS=10000
DASHBOARD_CACHE_TTL_MS=10000

# Supabase Storage for food scan uploads (optional in local dev, recommended in production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=food-scans
# Optional override when bucket is served through custom CDN/public URL
SUPABASE_STORAGE_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public/food-scans
