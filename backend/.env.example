# Server Configuration
PORT=3001
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=development

# API Configuration
API_URL=http://localhost:3001

# Food AI
FOOD_AI_INFERENCE_URL=http://localhost:8000/food-scans/detections
FOOD_AI_TIMEOUT_MS=10000
FOOD_AI_ALLOW_LOCAL_FALLBACK=false
FOOD_REASONING_API_URL=http://ai.jivara.web.id
FOOD_REASONING_TIMEOUT_MS=10000

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
FRONTEND_URL=http://localhost:3000

# Web Push Configuration (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@jivara.app

# Medication Reminder Scheduler
ENABLE_REMINDER_SCHEDULER=true
REMINDER_SCHEDULER_INTERVAL_MS=60000
REMINDER_LOOKBACK_MINUTES=2

# Supabase Storage for food scan uploads (optional in local dev, recommended in production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=food-scans
# Optional override when bucket is served through custom CDN/public URL
SUPABASE_STORAGE_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public/food-scans
